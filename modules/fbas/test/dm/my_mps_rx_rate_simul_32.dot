digraph G {

// Commands to run this schedule
// $ dm-sched dev/wbm1 add <path_to_this_file>            # load pattern
// $ dm-cmd dev/wbm1 startpattern PatA                    # start pattern
// $ dm-cmd dev/wbm1 status -v                            # show sent message counts
// $ dm-cmd dev/wbm1 cleardiag                            # clear diagnostics

// This schedule is used to test the maximum data rate for SCU receiver.
// A bunch of timing messages are generated and sent by DM with different data rate and
// allowed maximum data rate is determined by counting lost messages on SCU.

// Each timing message with event ID 4043 (0xfcb) contains a pseudo MPS protocol in its
// parameter field:
// - parameter (8-byte): sender ID (6) + index (1) + MPS_flag (1)
// where:
// - sender ID: MAC address
// - index: MPS channel index
// - MPS_flag: OK (=0), NOK (=1), TEST (=3)

// NOK->OK event by 16 senders is simulated with the given schedule:
// 2 blocks of 16 timing messages (M_A1..M_A16, M_A17..M_A32), each with different dev_ID,
// will be sent *simultaneously* in a period of 'tperiod' [ns].
// Iterations are 'qty' + 1 => to send 6000 timing messages, blocks should be iterated 375 times.
// Message rates of 300/600/1000/1200/1500 Hz (264/528/880/1056/1320 Kbps) are achieved by
// setting the 'tperiod' value to 53333/26666/16000/13333 us.

name="pseudo_MPS"
graph [rankdir   = TB, nodesep           = 0.6, mindist     = 1.0, ranksep = 1.0, overlap = false]
node [cpu="0", pattern=PatA, patentry=0, patexit=0,  style     = "filled", fillcolor = "white", color = "black"];
edge [type="defdst"];

C_A0 [type="flow",  patentry=1, toffs=0, qty="374", tvalid="0", vabs="true"];
M_A1 [type="tmsg",  patentry=1, toffs=0, fid=1, gid=4043, evtno=4043, sid="0", bpid="0", par="0xffffffffff010001"];
M_A2 [type="tmsg",              toffs=0, fid=1, gid=4043, evtno=4043, sid="0", bpid="0", par="0xffffffffff020101"];
M_A3 [type="tmsg",              toffs=0, fid=1, gid=4043, evtno=4043, sid="0", bpid="0", par="0xffffffffff030201"];
M_A4 [type="tmsg",              toffs=0, fid=1, gid=4043, evtno=4043, sid="0", bpid="0", par="0xffffffffff040301"];
M_A5 [type="tmsg",              toffs=0, fid=1, gid=4043, evtno=4043, sid="0", bpid="0", par="0xffffffffff050401"];
M_A6 [type="tmsg",              toffs=0, fid=1, gid=4043, evtno=4043, sid="0", bpid="0", par="0xffffffffff060501"];
M_A7 [type="tmsg",              toffs=0, fid=1, gid=4043, evtno=4043, sid="0", bpid="0", par="0xffffffffff070601"];
M_A8 [type="tmsg",              toffs=0, fid=1, gid=4043, evtno=4043, sid="0", bpid="0", par="0xffffffffff080701"];
M_A9 [type="tmsg",              toffs=0, fid=1, gid=4043, evtno=4043, sid="0", bpid="0", par="0xffffffffff090801"];
M_A10 [type="tmsg",             toffs=0, fid=1, gid=4043, evtno=4043, sid="0", bpid="0", par="0xffffffffff0a0901"];
M_A11 [type="tmsg",             toffs=0, fid=1, gid=4043, evtno=4043, sid="0", bpid="0", par="0xffffffffff0b0a01"];
M_A12 [type="tmsg",             toffs=0, fid=1, gid=4043, evtno=4043, sid="0", bpid="0", par="0xffffffffff0c0b01"];
M_A13 [type="tmsg",             toffs=0, fid=1, gid=4043, evtno=4043, sid="0", bpid="0", par="0xffffffffff0d0c01"];
M_A14 [type="tmsg",             toffs=0, fid=1, gid=4043, evtno=4043, sid="0", bpid="0", par="0xffffffffff0e0d01"];
M_A15 [type="tmsg",             toffs=0, fid=1, gid=4043, evtno=4043, sid="0", bpid="0", par="0xffffffffff0f0e01"];
M_A16 [type="tmsg",             toffs=0, fid=1, gid=4043, evtno=4043, sid="0", bpid="0", par="0xffffffffff100f01"];
M_A17 [type="tmsg",             toffs=1000, fid=1, gid=4043, evtno=4043, sid="0", bpid="0", par="0xffffffffff010000"];
M_A18 [type="tmsg",             toffs=1000, fid=1, gid=4043, evtno=4043, sid="0", bpid="0", par="0xffffffffff020100"];
M_A19 [type="tmsg",             toffs=1000, fid=1, gid=4043, evtno=4043, sid="0", bpid="0", par="0xffffffffff030200"];
M_A20 [type="tmsg",             toffs=1000, fid=1, gid=4043, evtno=4043, sid="0", bpid="0", par="0xffffffffff040300"];
M_A21 [type="tmsg",             toffs=1000, fid=1, gid=4043, evtno=4043, sid="0", bpid="0", par="0xffffffffff050400"];
M_A22 [type="tmsg",             toffs=1000, fid=1, gid=4043, evtno=4043, sid="0", bpid="0", par="0xffffffffff060500"];
M_A23 [type="tmsg",             toffs=1000, fid=1, gid=4043, evtno=4043, sid="0", bpid="0", par="0xffffffffff070600"];
M_A24 [type="tmsg",             toffs=1000, fid=1, gid=4043, evtno=4043, sid="0", bpid="0", par="0xffffffffff080700"];
M_A25 [type="tmsg",             toffs=1000, fid=1, gid=4043, evtno=4043, sid="0", bpid="0", par="0xffffffffff090800"];
M_A26 [type="tmsg",             toffs=1000, fid=1, gid=4043, evtno=4043, sid="0", bpid="0", par="0xffffffffff0a0900"];
M_A27 [type="tmsg",             toffs=1000, fid=1, gid=4043, evtno=4043, sid="0", bpid="0", par="0xffffffffff0b0a00"];
M_A28 [type="tmsg",             toffs=1000, fid=1, gid=4043, evtno=4043, sid="0", bpid="0", par="0xffffffffff0c0b00"];
M_A29 [type="tmsg",             toffs=1000, fid=1, gid=4043, evtno=4043, sid="0", bpid="0", par="0xffffffffff0d0c00"];
M_A30 [type="tmsg",             toffs=1000, fid=1, gid=4043, evtno=4043, sid="0", bpid="0", par="0xffffffffff0e0d00"];
M_A31 [type="tmsg",             toffs=1000, fid=1, gid=4043, evtno=4043, sid="0", bpid="0", par="0xffffffffff0f0e00"];
M_A32 [type="tmsg",             toffs=1000, fid=1, gid=4043, evtno=4043, sid="0", bpid="0", par="0xffffffffff100f00"];
B_A16 [type="block",            tperiod=26666666, qlo="true"];

C_A0 -> M_A1 -> M_A2 -> M_A3 -> M_A4 -> M_A5 -> M_A6 -> M_A7 -> M_A8 ->
M_A9 -> M_A10 -> M_A11 -> M_A12 -> M_A13 -> M_A14 -> M_A15 -> M_A16 ->
M_A17 -> M_A18 -> M_A19 -> M_A20 -> M_A21 -> M_A22 -> M_A23 -> M_A24 ->
M_A25 -> M_A26 -> M_A27 -> M_A28 -> M_A29 -> M_A30 -> M_A31 -> M_A32 -> B_A16;

B_A16 -> M_A1 [type="altdst"];
C_A0 -> M_A1 [type="flowdst"];
C_A0 -> B_A16 [type="target"];

}
